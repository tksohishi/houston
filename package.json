{
  "name": "houston",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "start": "bun run src/index.ts",
    "dev": "mkdir -p tmp && pkill -f 'bun.*src/index.ts' 2>/dev/null; sleep 0.5 && bun --watch run src/index.ts --verbose 2>&1 | tee -a tmp/houston.log",
    "setup": "bun run scripts/setup.ts",
    "reset": "bun run scripts/setup.ts --reset-only",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "bun-types": "^1.3.10",
    "typescript": "^5.8.2"
  }
}
