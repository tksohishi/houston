{
  "name": "houston",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "start": "bun run src/index.ts",
    "dev": "script -q tmp/dev.log bun --watch run src/index.ts --verbose",
    "setup": "bun run scripts/setup.ts",
    "reset": "bun run scripts/setup.ts --reset-only",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "bun-types": "^1.3.10",
    "typescript": "^5.8.2"
  }
}
